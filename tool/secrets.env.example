# S12 — local dev secrets TEMPLATE (committed). Copy to `tool/secrets.env`
# (gitignored) and fill in your own keys. NEVER commit the filled file.
#
#   cp tool/secrets.env.example tool/secrets.env
#   # edit tool/secrets.env with your keys, then:
#   ./tool/run_with_keys.sh            # flutter run -d chrome with the keys
#   ./tool/run_with_keys.sh build      # flutter build web --release with the keys
#
# Each key is OPTIONAL: a provider whose key is missing degrades gracefully
# (empty result + "needs key" status, no crash). Open-Meteo (weather) is keyless.

GEOAPIFY_KEY=
FOURSQUARE_KEY=
TMDB_KEY=
TICKETMASTER_KEY=
